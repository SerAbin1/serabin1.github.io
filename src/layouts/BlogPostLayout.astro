---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date } = post.data;

// Format date for display
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// JSON-LD schema
const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": date,
  "author": {
    "@type": "Person",
    "name": "Abin Biju",
    "url": Astro.site?.toString()
  }
};
---

<BaseLayout title={`${title} | Abin Biju`} description={description} ogType="article">
  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="container max-w-4xl mx-auto px-4 py-16 md:py-24">
    <!-- Back to Index Navigation -->
    <a 
      href="/blogs" 
      class="inline-flex items-center text-sm text-muted-foreground hover:text-terminal-green transition-colors mb-8"
      data-astro-prefetch
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Back to all posts
    </a>

    <!-- Article Header -->
    <header class="mb-12 border-b border-border pb-8 text-left">
      <div class="flex items-center gap-4 text-sm text-muted-foreground mb-4">
        <time datetime={date} class="flex items-center font-mono">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
          </svg>
          {formattedDate}
        </time>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-foreground mb-4 font-mono">
        {title}
      </h1>
      <p class="text-xl text-muted-foreground">
        {description}
      </p>
    </header>

    <!-- MDX Content -->
    <article class="prose prose-invert prose-terminal max-w-none text-left prose-headings:font-mono prose-headings:text-foreground prose-a:text-terminal-green hover:prose-a:text-terminal-green-bright prose-pre:!bg-[#0d1117] prose-pre:rounded-lg prose-pre:p-4 prose-pre:-mx-4 sm:prose-pre:mx-0 prose-pre:text-sm prose-pre:overflow-x-auto">
      <slot />
    </article>
  </div>
</BaseLayout>

<style is:global>
  /* Base typography for the article container */
  .prose-terminal {
    font-size: 1.05rem;
    line-height: 1.7;
  }
  
  .prose-terminal p {
    margin-bottom: 1.5em;
  }
  
  /* Link hover states */
  .prose-terminal a {
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: all 0.2s ease;
  }
  
  .prose-terminal a:hover {
    text-decoration-color: hsl(var(--terminal-green));
  }
  
  /* Headings spacing */
  .prose-terminal h2 {
    margin-top: 2em;
    margin-bottom: 0.8em;
  }
  
  .prose-terminal h3 {
    margin-top: 1.5em;
    margin-bottom: 0.6em;
  }
</style>
